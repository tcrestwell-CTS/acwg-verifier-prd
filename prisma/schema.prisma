generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ─── Existing models ──────────────────────────────────────────────────────────

model Order {
  id              String             @id @default(cuid())
  customerName    String
  email           String
  phone           String
  billingAddress  Json
  shippingAddress Json
  items           Json
  paymentMeta     Json
  context         Json
  createdAt       DateTime           @default(now())
  updatedAt       DateTime           @updatedAt

  verification    VerificationResult?
  decisions       Decision[]
  auditLogs       AuditLog[]
  documentRequests DocumentRequest[]
  otpAttempts     OtpAttempt[]
  stepUpResults   StepUpResult[]
  chargebacks     ChargebackRecord[]

  @@index([email])
  @@index([createdAt])
}

model VerificationResult {
  id        String   @id @default(cuid())
  orderId   String   @unique
  address   Json
  phone     Json
  email     Json
  payment   Json
  ip        Json
  overall   Json
  createdAt DateTime @default(now())

  order     Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@index([orderId])
}

model Decision {
  id         String         @id @default(cuid())
  orderId    String
  status     DecisionStatus
  reasons    Json
  notes      String?
  decidedBy  String
  decidedAt  DateTime       @default(now())

  order      Order          @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@index([orderId])
  @@index([status])
}

model AuditLog {
  id        String   @id @default(cuid())
  orderId   String?
  actor     String
  action    String
  payload   Json
  createdAt DateTime @default(now())

  order     Order?   @relation(fields: [orderId], references: [id], onDelete: SetNull)

  @@index([orderId])
  @@index([createdAt])
}

// ─── Sprint 3: Rules versioning ───────────────────────────────────────────────

model RulesVersion {
  id          String      @id @default(cuid())
  version     Int
  status      RulesStatus @default(draft)
  rules       Json        // full risk-rules config object
  description String?
  createdBy   String
  publishedBy String?
  publishedAt DateTime?
  createdAt   DateTime    @default(now())

  @@index([status])
  @@index([version])
}

// ─── Sprint 3: Document requests ─────────────────────────────────────────────

model DocumentRequest {
  id          String        @id @default(cuid())
  orderId     String
  type        DocRequestType
  status      DocStatus     @default(pending)
  requestedBy String
  notes       String?
  uploadUrl   String?       // pre-signed or secure token link
  fileName    String?       // safe filename, no raw path
  reviewedBy  String?
  reviewNotes String?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  order       Order         @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@index([orderId])
  @@index([status])
}

// ─── Sprint 3: OTP attempts ───────────────────────────────────────────────────

model OtpAttempt {
  id          String    @id @default(cuid())
  orderId     String
  phone       String    // E.164, never log the code itself
  status      OtpStatus @default(pending)
  attempts    Int       @default(0)
  expiresAt   DateTime
  verifiedAt  DateTime?
  createdAt   DateTime  @default(now())

  order       Order     @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@index([orderId])
}

// ─── Sprint 3: 3DS step-up ───────────────────────────────────────────────────

model StepUpResult {
  id           String       @id @default(cuid())
  orderId      String
  provider     String       // e.g. "stripe_3ds", "stub"
  status       StepUpStatus @default(initiated)
  acsUrl       String?
  challengeId  String?
  outcome      String?      // "authenticated" | "declined" | "attempted" | "unavailable"
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt

  order        Order        @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@index([orderId])
}

// ─── Sprint 3: Chargebacks ────────────────────────────────────────────────────

model ChargebackRecord {
  id              String            @id @default(cuid())
  orderId         String
  reason          String
  amount          Float
  currency        String            @default("USD")
  chargebackDate  DateTime
  reportedBy      String
  notes           String?
  status          ChargebackStatus  @default(open)
  resolution      String?
  resolvedAt      DateTime?
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt

  order           Order             @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@index([orderId])
  @@index([status])
}

// ─── Sprint 3: Background jobs ────────────────────────────────────────────────

model QueueJob {
  id          String    @id @default(cuid())
  type        String    // e.g. "verify_vendor", "send_otp", "send_alert"
  payload     Json
  status      JobStatus @default(pending)
  attempts    Int       @default(0)
  maxAttempts Int       @default(3)
  runAt       DateTime  @default(now())
  lastError   String?
  completedAt DateTime?
  createdAt   DateTime  @default(now())

  @@index([status])
  @@index([runAt])
  @@index([type])
}

// ─── Enums ────────────────────────────────────────────────────────────────────

enum DecisionStatus {
  approved
  queued
  denied
}

enum RulesStatus {
  draft
  published
  archived
}

enum DocRequestType {
  government_id
  proof_of_address
  bank_statement
  selfie
  other
}

enum DocStatus {
  pending
  uploaded
  reviewing
  accepted
  rejected
}

enum OtpStatus {
  pending
  verified
  failed
  expired
}

enum StepUpStatus {
  initiated
  challenged
  authenticated
  declined
  failed
}

enum ChargebackStatus {
  open
  investigating
  won
  lost
  resolved
}

enum JobStatus {
  pending
  running
  completed
  failed
  dead_letter
}
