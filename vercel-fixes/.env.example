# ─── Supabase / Postgres ──────────────────────────────────────────────────────
#
# DATABASE_URL  → Supabase connection POOLER URL (port 6543, PgBouncer)
#                 Used by Vercel serverless functions at runtime
#                 Project Settings → Database → Connection Pooling → Connection string
#                 Append: ?pgbouncer=true&connection_limit=1
#
# DIRECT_URL    → Supabase DIRECT connection URL (port 5432)
#                 Used only by `prisma migrate` — never hits serverless
#                 Project Settings → Database → Connection string (URI)
#
DATABASE_URL="postgresql://postgres.[PROJECT-REF]:[PASSWORD]@aws-0-us-east-1.pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=1"
DIRECT_URL="postgresql://postgres:[PASSWORD]@db.[PROJECT-REF].supabase.co:5432/postgres"

# ─── Address Verification (Smarty) ───────────────────────────────────────────
# https://www.smarty.com → API Keys
# Leave blank → stub responses used (safe for dev/staging)
SMARTY_AUTH_ID=""
SMARTY_AUTH_TOKEN=""

# ─── Phone Verification (Twilio Lookup) ──────────────────────────────────────
# https://console.twilio.com → Account Info
# Leave blank → stub responses used
TWILIO_ACCOUNT_SID=""
TWILIO_AUTH_TOKEN=""

# ─── AI Summaries (Anthropic Claude) ─────────────────────────────────────────
# https://console.anthropic.com/keys
# Leave blank → deterministic fallback text returned (no AI calls made)
ANTHROPIC_API_KEY=""

# ─── App ──────────────────────────────────────────────────────────────────────
NODE_ENV="development"

# ─── Free services (no key needed) ───────────────────────────────────────────
# Email MX checks   → Node dns.resolveMx (built-in)
# IP geolocation    → ip-api.com free tier (45 req/min)
# BIN lookup        → binlist.net free tier
