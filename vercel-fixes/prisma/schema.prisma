generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  // DATABASE_URL = Supabase pooler URL (port 6543) — used by serverless functions at runtime
  // DIRECT_URL   = Supabase direct URL (port 5432) — used by prisma migrate only
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Order {
  id              String             @id @default(cuid())
  customerName    String
  email           String
  phone           String
  billingAddress  Json
  shippingAddress Json
  items           Json
  paymentMeta     Json
  context         Json
  createdAt       DateTime           @default(now())
  updatedAt       DateTime           @updatedAt

  verification    VerificationResult?
  decisions       Decision[]
  auditLogs       AuditLog[]

  @@index([email])
  @@index([createdAt])
}

model VerificationResult {
  id        String   @id @default(cuid())
  orderId   String   @unique
  address   Json
  phone     Json
  email     Json
  payment   Json
  ip        Json
  overall   Json
  createdAt DateTime @default(now())

  order     Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@index([orderId])
}

model Decision {
  id         String         @id @default(cuid())
  orderId    String
  status     DecisionStatus
  reasons    Json
  notes      String?
  decidedBy  String
  decidedAt  DateTime       @default(now())

  order      Order          @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@index([orderId])
  @@index([status])
}

model AuditLog {
  id        String   @id @default(cuid())
  orderId   String?
  actor     String
  action    String
  payload   Json
  createdAt DateTime @default(now())

  order     Order?   @relation(fields: [orderId], references: [id], onDelete: SetNull)

  @@index([orderId])
  @@index([createdAt])
}

enum DecisionStatus {
  approved
  queued
  denied
}
